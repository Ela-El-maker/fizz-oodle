# Core
ENV=dev
APP_NAME=market-intel
API_KEY=replace_with_strong_api_key
INTERNAL_API_KEY=replace_with_strong_internal_api_key
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=replace_with_strong_password
SESSION_AUTH_ENABLED=true
SESSION_SECRET=replace_with_strong_session_secret
SESSION_COOKIE_NAME=mip_session
SESSION_TTL_SECONDS=43200
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
TZ=Africa/Nairobi

# Database / Queue
DATABASE_URL=postgresql+asyncpg://marketintel:marketintel@postgres:5432/market_intel
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_COMMANDS=commands.run.v1
REDIS_STREAM_RUN_EVENTS=runs.events.v1
REDIS_STREAM_ANALYST_REPORTS=analyst.report.generated.v1
REDIS_STREAM_ARCHIVIST_PATTERNS=archivist.patterns.updated.v1
RUN_DB_WRITE_ENABLED=false
REDIS_STREAM_MAXLEN=10000
STALE_RUN_RECONCILER_ENABLED=true
STALE_RUN_RECONCILER_INTERVAL_SECONDS=60
ANNOUNCEMENTS_STALE_RUN_TTL_MINUTES=20

# Email
EMAIL_FROM=briefing@yourdomain.com
EMAIL_RECIPIENTS=you@example.com
EMAIL_PROVIDER=auto
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_DRY_RUN=true
EMAIL_EXEC_DIGEST_ENABLED=true
EMAIL_EXEC_DIGEST_PARALLEL_LEGACY=true
EMAIL_EXEC_DIGEST_PARALLEL_DAYS=7
EMAIL_ALERTS_HIGH_IMPACT_ONLY=true
EMAIL_ALERTS_KENYA_IMPACT_THRESHOLD=60
EMAIL_EXEC_DIGEST_USE_AGENT_F=true
EMAIL_EXEC_DIGEST_MAX_STORIES=12
EMAIL_EXEC_DIGEST_INCLUDE_GLOSSARY=true
EMAIL_VALIDATION_ENABLED=true
EMAIL_VALIDATION_RECIPIENTS=qa@example.com
EMAIL_VALIDATION_DAILY_HOUR_EAT=10
EMAIL_VALIDATION_WEEKLY_HOUR_EAT=9
EMAIL_VALIDATION_WAIT_TIMEOUT_SECONDS=180
EMAIL_VALIDATION_POLL_INTERVAL_SECONDS=2

# Telegram (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scraping
REQUEST_TIMEOUT=30
PER_DOMAIN_MIN_DELAY_SECONDS=2
HTTP_RETRIES=3
HTTP_BACKOFF_BASE=2
USER_AGENT=MarketIntelBot/1.0
ALPHA_VANTAGE_API_KEY=
ENABLED_ANNOUNCEMENT_SOURCES=all
ENABLE_GLOBAL_OUTSIDE_SOURCES=true
GLOBAL_OUTSIDE_KENYA_IMPACT_THRESHOLD=60
ENABLE_PREMIUM_GLOBAL_SOURCES=false
ENABLE_SITEMAP_SOURCES=true
ENABLE_GLOBAL_MARKETS_THEME_PACK=true
ENABLE_GLOBAL_EXTRAS_PACK=true
SITEMAP_MAX_URLS_PER_SOURCE=200
SITEMAP_LOOKBACK_HOURS=72
SOURCE_HEALTH_FAIL_OPEN=false
ANNOUNCEMENTS_LOOKBACK_DAYS=30
ANNOUNCEMENTS_MAX_ITEMS_PER_SOURCE=500
ANNOUNCEMENTS_ALERT_CANDIDATE_LIMIT=40
ANNOUNCEMENTS_DETAILS_ENRICH_LIMIT=8
ANNOUNCEMENTS_DETAILS_ENRICH_TIMEOUT_SECONDS=8
ANNOUNCEMENTS_COMPANY_IR_MAX_COMPANIES_PER_RUN=10
ANNOUNCEMENTS_COMPANY_IR_CONCURRENCY=4
ANNOUNCEMENTS_SOURCE_COLLECTION_MAX_SECONDS=45
SOURCE_BREAKER_ENABLED=true
SOURCE_FAIL_THRESHOLD=3
SOURCE_COOLDOWN_MINUTES=120
COMPANY_IR_CONFIG_PATH=config/company_ir.yml
ANNOUNCEMENT_LLM_CONFIDENCE_THRESHOLD=0.70
ANNOUNCEMENT_LLM_MAX_CALLS_PER_RUN=25
ANNOUNCEMENT_LLM_MAX_CONCURRENCY=5
ANNOUNCEMENT_LLM_BREAKER_FAIL_THRESHOLD=3
ANNOUNCEMENT_LLM_TIMEOUT_SECONDS=8

# LLM policy
LLM_MODE=off
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
LLM_API_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=
LLM_MODEL=meta/llama-3.3-70b-instruct
LLM_PROVIDER=openai-compatible
LLM_HEALTHCHECK_NETWORK=true
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
X_API_BEARER_TOKEN=
X_NITTER_BASE_URL=https://nitter.net
YOUTUBE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Feature flags
ENABLE_AGENT_A=true
ENABLE_AGENT_B=true
ENABLE_AGENT_C=true
ENABLE_AGENT_D=true
ENABLE_AGENT_E=true

# Stage 3 (Daily Briefing)
DAILY_BRIEFING_ENABLED=true
DAILY_BRIEFING_RUN_HOUR_EAT=8
DAILY_BRIEFING_FORCE_SEND=false
DAILY_BRIEFING_LOOKBACK_DAYS=7
ENABLED_PRICE_SOURCES=alpha_vantage,mystocks,nse_market_stats_prices
ENABLED_INDEX_SOURCES=nse_market_stats,mystocks
ENABLED_FX_SOURCES=erapi
ENABLED_NEWS_SOURCES=standard_rss,google_news_ke,bbc_business_rss,mystocks_news,theonlinekenyan_feed,kenyans_sitemap_news,pulse_ke_sitemap_news,infoworld_feed,eia_today_in_energy,world_bank_commodity_markets,fred_dollar_index_broad,google_research_blog,google_deepmind_blog,anthropic_news,durovscode_site,investing_major_indices,global_bonds_yields_rss,global_earnings_dividends_rss,global_equities_trading_rss
AGENT_A_MIN_PRICE_COVERAGE_PCT=0.6
AGENT_A_PRICE_MAX_CONCURRENCY=4
AGENT_A_FX_STALE_TTL_HOURS=24
AGENT_A_FX_HARD_STALE_TTL_HOURS=72
AGENT_A_INDEX_MIN_VALUE=100
AGENT_A_INDEX_MAX_VALUE=20000
AGENT_A_INDEX_MAX_PCT_MOVE=25
AGENT_A_NEWS_MAX_ITEMS_PER_SOURCE=25
AGENT_A_ENABLE_NEWS_HTML_SOURCES=false
AGENT_A_BRIEF_LLM_TIMEOUT_SECONDS=12
AGENT_A_BRIEF_LLM_MAX_TOKENS=300
AGENT_A_CHART_OUTPUT_DIR=docs/evidence/agent_a/charts
AGENT_A_CHART_ENABLE_VOLUME_OVERLAY=true

# Stage 4 (Weekly Sentiment)
SENTIMENT_ENABLED=true
SENTIMENT_WEEKLY_HOUR_EAT=7
SENTIMENT_FORCE_RESEND=false
SENTIMENT_WINDOW_DAYS=7
ENABLED_SENTIMENT_SOURCES=reddit_rss,x_search_api,youtube_api,mystocks_forum,stockswatch_forum,business_daily_comments,standardmedia_comments,google_news_ke_markets,google_news_ke_companies,google_news_ke_banking,google_news_ke_dividends,bbc_business_rss,standard_business_rss,eia_oil_theme_rss,global_oil_theme_rss,global_usd_theme_rss,global_ai_theme_rss,global_bonds_theme_rss,global_earnings_dividends_theme_rss,global_equities_trading_theme_rss,theonlinekenyan_feed,kenyans_sitemap_news,pulse_ke_sitemap_news,infoworld_feed,google_research_blog,google_deepmind_blog,anthropic_news,durovscode_site,investing_major_indices
SENTIMENT_CONFIDENCE_THRESHOLD=0.70
SENTIMENT_THRESHOLD_BULL=0.20
SENTIMENT_THRESHOLD_BEAR=-0.20
SENTIMENT_MIN_MENTIONS_PER_TICKER=3
SENTIMENT_LLM_MAX_CALLS_PER_RUN=25
SENTIMENT_LLM_BREAKER_FAIL_THRESHOLD=5
SENTIMENT_CONFIG_PATH=config/sentiment_sources.yml

# Stage 5 (Analyst Synthesizer)
ANALYST_ENABLED=true
ANALYST_DAILY_HOUR_EAT=9
ANALYST_WEEKLY_HOUR_EAT=8
ANALYST_FORCE_RESEND=false
ANALYST_LOOKBACK_DAYS=7
ANALYST_MAX_EVENTS=30
ANALYST_MIN_CONFIDENCE_FOR_STRONG_LANGUAGE=0.70
ANALYST_REPORT_TYPES=daily,weekly

# Stage 6 (Archivist)
ARCHIVIST_PROMOTION_THRESHOLD_PCT=65
ARCHIVIST_RETIRE_THRESHOLD_PCT=45
ARCHIVIST_MIN_OCCURRENCES_FOR_CONFIRM=5
ARCHIVIST_MIN_OCCURRENCES_FOR_RETIRE=8
ARCHIVIST_MONTHLY_LOOKBACK_WEEKS=12
ARCHIVIST_WEEKLY_LOOKBACK_DAYS=30
ARCHIVIST_ENABLE_EMAIL_REPORTS=true
ARCHIVIST_FORCE_RESEND=false

# Stage 7 (Narrator / Agent F)
NARRATOR_ENABLED=true
NARRATOR_CACHE_TTL_MINUTES=360
NARRATOR_TIMEOUT_SECONDS=20
NARRATOR_MAX_TOKENS=500
NARRATOR_CONTEXT_MAX_SOURCES=5
NARRATOR_MIN_COVERAGE_SCORE=0.6
NARRATOR_STALE_RUN_TTL_MINUTES=30
NARRATOR_LLM_RETRY_ATTEMPTS=3
NARRATOR_LLM_BACKOFF_BASE_SECONDS=1.0
NARRATOR_LLM_CONNECT_TIMEOUT_SECONDS=10
NARRATOR_LLM_READ_TIMEOUT_SECONDS=90
NARRATOR_MARKET_STORY_MAX_AGE_MINUTES=60
NARRATOR_DEGRADED_RETRY_MINUTES=10

# Microservice internal routing
GATEWAY_SERVICE_URL=http://gateway-service:8000
AGENT_A_SERVICE_URL=http://agent-a-service:8001
AGENT_B_SERVICE_URL=http://agent-b-service:8002
AGENT_C_SERVICE_URL=http://agent-c-service:8003
AGENT_D_SERVICE_URL=http://agent-d-service:8004
AGENT_E_SERVICE_URL=http://agent-e-service:8005
AGENT_F_SERVICE_URL=http://agent-f-service:8006
GATEWAY_PROXY_TIMEOUT_SECONDS=90

# Monitoring (optional)
FLOWER_BASIC_AUTH=

# Stage 7 (Production Readiness / Ops)
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_password
ALERTMANAGER_ENABLED=true

# Backup + restore (S3-compatible target)
S3_ENDPOINT_URL=
S3_BUCKET=market-intel-backups
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=market-intel
BACKUP_ENCRYPTION_KEY=replace_with_32_byte_key
BACKUP_RETENTION_DAYS=30

# Deployment image tag (staging/prod compose profiles)
APP_IMAGE=ghcr.io/your-org/fizz-oodle:latest

# Frontend
NEXT_PUBLIC_APP_NAME=Market Intel Platform
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
