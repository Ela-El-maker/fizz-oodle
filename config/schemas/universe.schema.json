{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "region", "timezone", "tracked_companies"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "region": {"type": "string", "minLength": 2},
    "timezone": {"type": "string", "const": "Africa/Nairobi"},
    "tracked_companies": {
      "type": "array",
      "minItems": 15,
      "items": {
        "type": "object",
        "required": ["ticker", "company_name", "exchange", "aliases"],
        "properties": {
          "ticker": {"type": "string", "pattern": "^[A-Z0-9]{2,16}$"},
          "company_name": {"type": "string", "minLength": 2},
          "exchange": {"type": "string", "minLength": 2},
          "aliases": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 2}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
